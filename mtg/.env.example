# Google sign-in — use Firebase (cloud decklists) OR a Google OAuth client id (local decklists).
# If Firebase is configured below, that takes priority and opens a real Google popup.

# Option A: Google OAuth client id (Google Cloud Console → OAuth 2.0 Client → Web)
VITE_GOOGLE_CLIENT_ID=

# Option B: Firebase (Google sign-in + Firestore saved decklists)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: deeper Judge chat answers via OpenAI (dev only — use a backend proxy in production)
VITE_OPENAI_API_KEY=
